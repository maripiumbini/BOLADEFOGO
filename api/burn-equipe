export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).send('Método não permitido');

    const { usuarios, token } = req.body; // Recebe a lista de GIDs e o token

    if (!usuarios || !token) {
        return res.status(400).json({ error: "Dados insuficientes para a missão." });
    }

    try {
        // 1. DEFINE AS DATAS
        const hoje = new Date().toISOString().split('T')[0];
        const amanhaData = new Date();
        amanhaData.setDate(amanhaData.getDate() + 1);
        const amanhaFormatado = amanhaData.toISOString().split('T')[0];

        let totalReagendadas = 0;

        // 2. O TRATOR PASSA POR CADA USUÁRIO SELECIONADO
        for (const userGid of usuarios) {
            // Buscamos as tarefas de cada colaborador (precisa ser no workspace dele)
            // Aqui buscamos as tarefas atribuídas a ESSE usuário específico
            const tasksResp = await fetch(`https://app.asana.com/api/1.0/tasks?assignee=${userGid}&workspace=me&completed_since=now&opt_fields=due_on,completed`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            
            const tasksData = await tasksResp.json();
            const tasks = tasksData.data || [];

            // 3. REAGENDAMENTO
            for (const task of tasks) {
                // Filtro: Não concluída E (Vencendo hoje ou atrasada)
                if (!task.completed && task.due_on && task.due_on <= hoje) {
                    await fetch(`https://app.asana.com/api/1.0/tasks/${task.gid}`, {
                        method: 'PUT',
                        headers: { 
                            'Authorization': `Bearer ${token}`,
                            'Content-Type': 'application/json' 
                        },
                        body: JSON.stringify({ data: { due_on: amanhaFormatado } })
                    });
                    totalReagendadas++;
                }
            }
        }

        return res.status(200).json({ success: true, reagendadas: totalReagendadas });

    } catch (error) {
        return res.status(500).json({ error: "Falha no motor da equipe", message: error.message });
    }
}
